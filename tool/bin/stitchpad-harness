#!/usr/bin/env bash
# Detect runtime + model from kitty window foreground processes.
# Usage: stitchpad-harness <socket> <window_id>
# Output: "runtime" or "runtime · model"
# Model: reads from .state/model.<name> if available, else auto-detects.
set -uo pipefail

kitty_bin="$(command -v kitty 2>/dev/null || echo /Applications/kitty.app/Contents/MacOS/kitty)"
sock="$1"; win="$2"

# Get foreground cmdline + window title in one kitty call
info="$("$kitty_bin" @ --to "$sock" ls 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
for os_win in data:
    for tab in os_win.get('tabs', []):
        for w in tab.get('windows', []):
            if str(w.get('id')) == sys.argv[1]:
                fp = w.get('foreground_processes', [])
                cmdline = ' '.join(fp[0].get('cmdline', [])) if fp else ''
                title = w.get('title', '')
                name = title.split('🧵 ')[-1] if '🧵' in title else ''
                print(cmdline)
                print(name)
                sys.exit(0)
" "$win" 2>/dev/null)"

cmdline="$(echo "$info" | sed -n '1p')"
name="$(echo "$info" | sed -n '2p')"

# Detect runtime from cmdline
runtime=""
case "$cmdline" in
  *claude*|*claude-code*) runtime="claude" ;;
  *codex*) runtime="codex" ;;
  *pi\ *|pi) runtime="pi" ;;
  *node*|*excalidraw*|*rust-analyzer*) runtime="node" ;;
  *) runtime="unknown" ;;
esac

# Model: check .state/model.<name> first, then auto-detect
pad_state="${SP_PAD_DIR:-$HOME/.stitchpad}/.state"
model_file="$pad_state/model.$name"
model=""

if [ -n "$name" ] && [ -f "$model_file" ]; then
  model="$(cat "$model_file" 2>/dev/null)"
elif [ "$runtime" = "pi" ]; then
  model="$(python3 -c "
import json
try:
    with open('$HOME/.pi/agent/settings.json') as f:
        print(json.load(f).get('defaultModel', ''))
except: pass
" 2>/dev/null)"
fi

# Output
if [ -n "$model" ]; then
  echo "$runtime · $model"
else
  echo "$runtime"
fi
