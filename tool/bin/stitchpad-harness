#!/usr/bin/env bash
# Detect runtime + model from kitty window foreground processes.
# Usage: stitchpad-harness <socket> <window_id>
# Output: "runtime" or "runtime · model"
set -uo pipefail

kitty_bin="$(command -v kitty 2>/dev/null || echo /Applications/kitty.app/Contents/MacOS/kitty)"
sock="$1"; win="$2"

# Get the foreground process cmdline for this window
cmdline="$("$kitty_bin" @ --to "$sock" ls 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
for os_win in data:
    for tab in os_win.get('tabs', []):
        for w in tab.get('windows', []):
            if str(w.get('id')) == sys.argv[1]:
                fp = w.get('foreground_processes', [])
                if fp:
                    print(' '.join(fp[0].get('cmdline', [])))
                sys.exit(0)
" "$win" 2>/dev/null)"

# Detect runtime from cmdline
runtime=""
model=""

case "$cmdline" in
  *claude*|*claude-code*) runtime="claude" ;;
  *codex*) runtime="codex" ;;
  *pi\ *) runtime="pi" ;;
  *node*|*excalidraw*|*rust-analyzer*) runtime="node" ;;
  *) runtime="unknown" ;;
esac

# Best-effort model detection
case "$runtime" in
  pi)
    # pi: read defaultModel from settings
    model="$(python3 -c "
import json, sys
try:
    with open('$HOME/.pi/agent/settings.json') as f:
        d = json.load(f)
        print(d.get('defaultModel', ''))
except: pass
" 2>/dev/null)"
    ;;
  claude|codex)
    # claude/codex: model not easily exposed
    model="—"
    ;;
esac

# Output
if [ -n "$model" ] && [ "$model" != "—" ]; then
  echo "$runtime · $model"
else
  echo "$runtime"
fi
