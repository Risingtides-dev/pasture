#!/usr/bin/env bash
# stitchpad — a model-agnostic agent channel that's just a markdown file.
#
#   stitchpad init [--name <pad>]         create .stitchpad/ in the current project
#   stitchpad join <name> <adapter> [wake] [target]   add a participant to the roster
#   stitchpad say <from> <text...>        post a message (auto-commits)
#   stitchpad read [-n N]                 print the recent conversation (plain)
#   stitchpad watch                       run the daemon (foreground)
#   stitchpad start|stop|status|restart   manage the daemon (background)
#   stitchpad roster                      print parsed roster
#   stitchpad who                         alias for roster
#   stitchpad log [-n N]                  show recent history (git log)
#
# The roster lives INSIDE stitchpad.md as a ```roster fenced block. To add an agent
# from any runtime (pi/codex/cline/claude), drop an adapter in ~/.stitchpad/adapters
# and add one roster line — or connect via the stitchpad MCP server. That's the
# whole extension model.
set -uo pipefail
# Resolve our real dir even when invoked through a symlink (install puts a
# symlink on PATH; lib.sh sits next to the real script).
_src="${BASH_SOURCE[0]}"; while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"; _src="$(readlink "$_src")"
  [ "${_src#/}" = "$_src" ] && _src="$_dir/$_src"
done
BIN_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
source "$BIN_DIR/lib.sh"

cmd="${1:-help}"; shift || true

case "$cmd" in
  init)
    name="$(basename "$PWD")"
    [ "${1:-}" = "--name" ] && name="$2"
    dir="$PWD/.stitchpad"; mkdir -p "$dir/.state"
    md="$dir/stitchpad.md"
    if [ -f "$md" ]; then echo "stitchpad already exists: $md"; exit 0; fi
    cat > "$md" <<EOF
# 🧵 #$name — agent stitchpad

> A model-agnostic channel that's just this markdown file. Any agent (pi, codex,
> cline, claude, …) joins by adding a line to the roster block below — or by
> connecting the stitchpad MCP server. Address someone by starting a line with
> @their-name. The watcher wakes them.

\`\`\`roster
# name | adapter | wake(push|pull) | target
\`\`\`

---
EOF
    # isolated git for the pad
    git --git-dir="$dir/stitchpad-git" --work-tree="$dir" init -q
    git --git-dir="$dir/stitchpad-git" --work-tree="$dir" config user.name "stitchpad"
    git --git-dir="$dir/stitchpad-git" --work-tree="$dir" config user.email "stitchpad@agents.local"
    printf '*\n!stitchpad.md\n' > "$dir/stitchpad-git/info/exclude"
    git --git-dir="$dir/stitchpad-git" --work-tree="$dir" add stitchpad.md
    git --git-dir="$dir/stitchpad-git" --work-tree="$dir" commit -q -m "stitchpad created"
    # gitignore runtime state in the project repo if there is one
    if [ -f "$PWD/.gitignore" ]; then
      grep -q '.stitchpad/.state' "$PWD/.gitignore" 2>/dev/null || printf '\n# stitchpad runtime\n.stitchpad/.state/\n.stitchpad/stitchpad-git/\n' >> "$PWD/.gitignore"
    fi
    echo "✓ stitchpad #$name created at $md"
    ;;

  join)
    sp_init_paths || exit 1
    who="${1:?usage: stitchpad join <name> <adapter> [wake] [target]}"
    adapter="${2:?adapter required (e.g. pi, claude, codex, mcp)}"
    wake="${3:-pull}"; target="${4:--}"
    if sp_user_exists "$who"; then echo "$who already in roster"; exit 0; fi
    # Insert before the closing fence of the roster block.
    tmp="$(mktemp)"
    awk -v line="$who | $adapter | $wake | $target" '
      /^```roster/ { inblk=1; print; next }
      inblk && /^```/ { print line; inblk=0; print; next }
      { print }
    ' "$PAD_MD" > "$tmp" && mv "$tmp" "$PAD_MD"
    sp_commit "roster: + $who ($adapter/$wake)"
    echo "✓ $who joined (adapter=$adapter wake=$wake)"
    ;;

  say)
    sp_init_paths || exit 1
    from="${1:?usage: stitchpad say <from> <text...>}"; shift
    text="$*"
    ts="$(date '+%H:%M')"
    printf '\n## %s · %s\n\n%s\n' "@$from" "$ts" "$text" >> "$PAD_MD"
    sp_commit "$from: $(printf '%s' "$text" | tr '\n' ' ' | cut -c1-60)"
    echo "✓ posted as @$from"
    ;;

  read)
    sp_init_paths || exit 1
    n=80; [ "${1:-}" = "-n" ] && n="$2"
    tail -n "$n" "$PAD_MD"
    ;;

  watch)   exec "$STITCHPAD_HOME/bin/watch.sh" ;;
  start|stop|status|restart) exec "$STITCHPAD_HOME/bin/daemon.sh" "$cmd" ;;

  roster|who)  sp_init_paths || exit 1; sp_roster ;;
  log)
    sp_init_paths || exit 1
    n=10; [ "${1:-}" = "-n" ] && n="$2"
    sgit log --oneline -n "$n"
    ;;

  help|*)
    sed -n '2,22p' "$0" | sed 's/^# \{0,1\}//'
    ;;
esac
